---
const { agent } = Astro.props;
---

<a
  href={`/agents/${agent.id}`}
  class="block h-full bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all overflow-hidden border-2 border-red-100 hover:border-red-300 group"
>
  <div class="p-5">
    <div class="flex items-center gap-4 mb-4">
      <div class="w-14 h-14 rounded-full bg-linear-to-r from-red-500 to-rose-500 text-white flex items-center justify-center font-bold text-lg shadow-md">
        {agent.nom?.[0] || "G"}{agent.prenom?.[0] || "A"}
      </div>
      <div>
        <h3 class="text-xl md:text-2xl font-bold text-red-700 group-hover:text-red-600 transition-colors">
          {agent.nom} {agent.prenom}
        </h3>
        <p class="text-sm text-red-500 font-medium">Agent immobilier</p>
      </div>
    </div>

    <div class="space-y-2 p-3 bg-linear-to-r from-red-50 to-rose-50 rounded-xl border border-red-100">
      {agent.email && (
        <div class="flex items-center gap-2 text-sm text-gray-700">
          <span class="text-red-600">📧</span>
          <span>{agent.email}</span>
        </div>
      )}

      {agent.telephone && (
        <div class="flex items-center gap-2 text-sm text-gray-700">
          <span class="text-red-600">📞</span>
          <span>{agent.telephone}</span>
        </div>
      )}

      {agent.specialite && (
        <div class="flex items-center gap-2 text-sm text-gray-700">
          <span class="text-red-600">🏅</span>
          <span>{agent.specialite}</span>
        </div>
      )}
    </div>

    <div class="mt-4 pt-4 border-t border-red-100 text-red-600 font-semibold text-sm group-hover:text-red-700 transition-colors">
      Voir le profil →
    </div>
  </div>
</a>