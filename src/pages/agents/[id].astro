---
import { getAgent } from '../../js/backend.mjs';
import Layout from '../../layouts/Layout.astro';
import PbImage from '../../components/PbImage.astro';
import OffreCard from '../../components/OffreCard.astro';

const { id } = Astro.params;
const agent = await getAgent(id);
const offres = agent?.expand?.field || [];
---

<Layout titre={agent ? `${agent.prenom} ${agent.nom || ''}` : 'Agent'}>
    <section class="py-20 px-6">
        <div class="max-w-6xl mx-auto">
            <a href="/agents" class="text-red-600 hover:text-red-700 mb-6 inline-block">← Retour aux agents</a>
            
            {agent ? (
                <>
                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden mb-12">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 p-8">
                            <div>
                                <div class="w-full h-80 bg-linear-to-br from-red-300 to-red-600 flex items-center justify-center text-white text-9xl rounded-lg">
                                    👤
                                </div>
                            </div>
                            
                            <div class="md:col-span-2">
                                <h1 class="text-5xl font-bold text-red-700 mb-2">
                                    {agent.prenom} {agent.nom}
                                </h1>
                                
                                <div class="space-y-4 text-gray-700">
                                    {agent.email && (
                                        <div class="flex items-center gap-3">
                                            <span class="text-red-600 font-medium">📧</span>
                                            <a href={`mailto:${agent.email}`} class="text-blue-600 hover:underline">
                                                {agent.email}
                                            </a>
                                        </div>
                                    )}
                                    
                                    {agent.telephone && (
                                        <div class="flex items-center gap-3">
                                            <span class="text-red-600 font-medium">📞</span>
                                            <a href={`tel:${agent.telephone}`} class="text-blue-600 hover:underline">
                                                {agent.telephone}
                                            </a>
                                        </div>
                                    )}
                                    
                                    {agent.specialite && (
                                        <div class="flex items-center gap-3">
                                            <span class="text-red-600 font-medium">🏅</span>
                                            <p>{agent.specialite}</p>
                                        </div>
                                    )}
                                </div>
                                
                                <div class="mt-6 p-4 bg-red-50 rounded-lg border-l-4 border-red-600">
                                    <p class="text-lg font-semibold text-red-700">
                                        {offres.length} offre{offres.length !== 1 ? 's' : ''} disponible{offres.length !== 1 ? 's' : ''}
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    {offres.length > 0 ? (
                        <div>
                            <h2 class="text-3xl font-bold text-red-700 mb-8">Ses offres</h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                                {offres.map((offre) => (
                                    <OffreCard offre={offre} />
                                ))}
                            </div>
                        </div>
                    ) : (
                        <div class="bg-red-100 text-red-800 p-6 rounded-lg text-center">
                            <p>Cet agent n'a pas encore d'offres disponibles.</p>
                        </div>
                    )}
                </>
            ) : (
                <div class="bg-red-100 text-red-800 p-6 rounded-lg text-center">
                    <p>Agent non trouvé</p>
                </div>
            )}
        </div>
    </section>
</Layout>
